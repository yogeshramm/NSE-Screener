# YOINTELL Caddy reverse proxy configuration
# Auto-HTTPS via Let's Encrypt — Caddy handles cert renewal automatically.
# Replaces {{DOMAIN}} with the actual domain at install time.

{{DOMAIN}}, www.{{DOMAIN}} {
    # Reverse proxy to uvicorn on localhost
    reverse_proxy 127.0.0.1:8000 {
        # Trust proxy headers from Cloudflare
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}

        # Long timeouts for slow NSE/screener.in fetches
        transport http {
            read_timeout 60s
            write_timeout 60s
        }
    }

    # Compress responses
    encode gzip zstd

    # Allow up to 10MB request bodies (preset uploads, etc.)
    request_body {
        max_size 10MB
    }

    # Security headers
    header {
        # Tell browsers to stick with HTTPS
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        # Prevent clickjacking
        X-Frame-Options "SAMEORIGIN"
        # MIME sniffing off
        X-Content-Type-Options "nosniff"
        # Referrer policy
        Referrer-Policy "strict-origin-when-cross-origin"
        # Hide server header
        -Server
    }

    # Log access for debugging
    log {
        output file /var/log/caddy/access.log {
            roll_size 100mb
            roll_keep 5
        }
        format json
    }
}
